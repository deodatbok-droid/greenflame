# =============================================================
# GREENFLAME — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# =============================================================

# --- Supabase ---
# Créer un projet sur https://supabase.com et récupérer ces valeurs
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- MTN MoMo API ---
# Sandbox : https://momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key
MTN_MOMO_API_USER=your_api_user_uuid
MTN_MOMO_API_KEY=your_api_key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CALLBACK_URL=https://your-domain.vercel.app/api/webhooks/momo

# --- Moov Money API ---
MOOV_API_KEY=your_moov_api_key
MOOV_ENVIRONMENT=sandbox

# --- Africa's Talking SMS ---
# https://africastalking.com
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SMS_SENDER=GRFLAME

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your_random_secret_min_32_chars

# --- Mode ---
# 'mock' en développement, 'live' en production
PAYMENT_MODE=mock

# --- Anthropic (IA suggestion de catégorie marketplace) ---
# Obtenir une clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- Automatisations internes (n8n) ---
# Clé secrète partagée entre GreenFlame et n8n pour protéger les routes /api/internal/*
# Générer avec : openssl rand -hex 32
INTERNAL_API_SECRET=your_internal_api_secret_min_32_chars
